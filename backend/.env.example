# Server Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/waveeProjectBW?schema=public"

# Spotify API - Get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"
SPOTIFY_REDIRECT_URI="http://127.0.0.1:3001/api/auth/callback"
SPOTIFY_REDIRECT_URIS="http://127.0.0.1:3001/api/auth/callback,http://localhost:3001/api/auth/callback"

# JWT Secret - Generate a random string
JWT_SECRET="your_super_secret_jwt_key_change_this"

# Client URL
CLIENT_URL="http://localhost:5173"

# Server Port
PORT=3001
