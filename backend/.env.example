# Server Environment Variables
# Skopiuj ten plik jako .env i uzupełnij wartości
# Przy deployowaniu na Railway/Render wpisz te wartości w panelu serwisu (nie jako plik)

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host/dbname?sslmode=require"

# Spotify API - skopiuj z https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID="your_spotify_client_id"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret"

# LOKALNE uruchomienie:
# SPOTIFY_REDIRECT_URI="http://127.0.0.1:3001/api/auth/callback"
# PO DEPLOYU na Railway — zmień na URL swojego backendu:
SPOTIFY_REDIRECT_URI="https://TWOJ-BACKEND.railway.app/api/auth/callback"

# JWT Secret — wygeneruj losowy ciąg, np: openssl rand -base64 32
JWT_SECRET="twoj_super_tajny_klucz_jwt"

# URL frontendu — lokalnie lub po deployu na Vercel:
# CLIENT_URL="http://localhost:5173"
CLIENT_URL="https://TWOJ-FRONTEND.vercel.app"

# Port (Railway ustawia automatycznie, nie zmieniaj)
PORT=3001
